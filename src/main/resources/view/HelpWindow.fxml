<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="false" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <BorderPane fx:id="helpMessageContainer">
        <center>
          <Label fx:id="helpMessage" text="Label" BorderPane.alignment="CENTER">
            <BorderPane.margin>
              <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
            </BorderPane.margin>
          </Label>
        </center>
        <bottom>
          <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <children>
              <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL" />
            </children>
            <padding>
              <Insets bottom="10.0" left="5.0" right="10.0" top="0.0" />
            </padding>
          </HBox>
        </bottom>
      </BorderPane>
    </Scene>
  </scene>
</fx:root>
